{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ],
  "functions": {
    "api/upload.js":   { "memory": 256, "maxDuration": 10 },
    "api/products.js": { "memory": 128, "maxDuration": 10 }
  }
}
